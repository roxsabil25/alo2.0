<div id="imageModal" class="fixed inset-0 z-[100] hidden bg-black/95 backdrop-blur-md flex items-center justify-center p-4 overflow-hidden touch-none">
    <button id="closeModal" class="absolute top-5 right-5 text-white text-4xl z-[110] hover:text-red-500">
        <i class="fas fa-times"></i>
    </button>
    
    <div id="zoomContainer" class="relative cursor-move">
        <img id="modalImg" src="" class="max-w-full max-h-[90vh] rounded-lg shadow-2xl transition-transform duration-200 ease-out select-none">
    </div>
