
<%- include('partials/header') %>
<section class="bg-green-900 py-16 px-4">
    <div class="max-w-7xl mx-auto text-center">
        <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-4">Our Stories & Updates</h1>
        <p class="text-green-100 max-w-2xl mx-auto text-lg">
            Stay updated with the latest news, success stories, and initiatives of ALO - Assistance for Landless Organization.
        </p>
    </div>
</section>

<section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4">
        
        <div class="flex flex-col md:flex-row justify-between items-center mb-12 gap-4">
            <div class="flex gap-2 overflow-x-auto pb-2 w-full md:w-auto">
                <button class="bg-green-600 text-white px-5 py-2 rounded-full text-sm font-semibold">All Posts</button>
                <button class="bg-white text-gray-600 hover:bg-green-100 px-5 py-2 rounded-full text-sm font-semibold transition">Agriculture</button>
                <button class="bg-white text-gray-600 hover:bg-green-100 px-5 py-2 rounded-full text-sm font-semibold transition">Education</button>
                <button class="bg-white text-gray-600 hover:bg-green-100 px-5 py-2 rounded-full text-sm font-semibold transition">Community</button>
            </div>
            <div class="relative w-full md:w-64">
                <input type="text" placeholder="Search stories..." class="w-full pl-10 pr-4 py-2 rounded-full border border-gray-200 focus:outline-none focus:ring-2 focus:ring-green-500">
                <i class="fa-solid fa-magnifying-glass absolute left-4 top-3 text-gray-400"></i>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
            
            <% blogs.forEach(function(project){ %>
            <article class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition duration-300 group">
                <div class="relative overflow-hidden">
                    <img src="<%= project.featuredImage %>" alt="Blog Image" class="w-full h-56 object-cover group-hover:scale-110 transition duration-500">
                    <span class="absolute top-4 left-4 bg-orange-500 text-white text-xs font-bold px-3 py-1 rounded-full uppercase"><%= project.category %></span>
                </div>
                <div class="p-6">
                    <div class="flex items-center gap-3 text-sm text-gray-500 mb-3">
                        <span><i class="fa-regular fa-calendar mr-1"></i> <%= new Date(project.createdAt).toLocaleDateString() %></span>
                        <span><i class="fa-regular fa-clock mr-1"></i> 5 min read</span>
                    </div>
                    <h3 class="text-xl font-bold text-gray-900 mb-3 group-hover:text-green-700 transition">
                         <%= project.projectTitle %>
                    </h3>
                    <p class="text-gray-600 text-sm leading-relaxed mb-5 line-clamp-3">
                       <%= project.excerpt %>
                    </p>

                    <a href="/stories/<%= project._id %>" class="text-green-600 font-bold text-sm flex items-center gap-2 hover:gap-3 transition-all">
                        READ MORE <i class="fa-solid fa-arrow-right"></i>
                    </a>
                </div>
            </article>


            <% }) %>
        </div>

        <div class="mt-16 flex justify-center gap-2">
            <button class="w-10 h-10 flex items-center justify-center rounded-lg bg-white border border-gray-200 text-gray-600 hover:bg-green-600 hover:text-white transition shadow-sm font-bold">1</button>
            <button class="w-10 h-10 flex items-center justify-center rounded-lg bg-white border border-gray-200 text-gray-600 hover:bg-green-600 hover:text-white transition shadow-sm font-bold">2</button>
            <button class="w-10 h-10 flex items-center justify-center rounded-lg bg-white border border-gray-200 text-gray-600 hover:bg-green-600 hover:text-white transition shadow-sm font-bold">
                <i class="fa-solid fa-chevron-right"></i>
            </button>
        </div>
    </div>
</section>

<section class="py-20 bg-orange-50 border-t border-orange-100">
    <div class="max-w-4xl mx-auto px-4 text-center">
        <div class="inline-block p-3 bg-orange-100 rounded-full mb-6">
            <i class="fa-solid fa-paper-plane text-orange-600 text-2xl"></i>
        </div>
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Subscribe to our newsletter</h2>
        <p class="text-gray-600 mb-8">Get the latest stories and updates directly in your inbox.</p>
        <form class="flex flex-col sm:flex-row gap-3 max-w-lg mx-auto">
            <input type="email" placeholder="Enter your email" class="flex-1 px-6 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-orange-500 shadow-sm" required>
            <button type="submit" class="bg-orange-600 text-white px-8 py-3 rounded-xl font-bold hover:bg-orange-700 transition shadow-lg shadow-orange-200">
                Subscribe
            </button>
        </form>
    </div>
</section>
<%- include('partials/footer') %>