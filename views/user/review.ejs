    /* স্লাইডিং অ্যানিমেশন */
    @keyframes scroll-left {
        from { transform: translateX(0); }
        to { transform: translateX(-50%); }
    }

    .scroll-wrapper {
        display: flex;
        width: fit-content;
        animation: scroll-left 40s linear infinite; /* গতি পরিবর্তন করতে 40s বাড়াতে বা কমাতে পারেন */
    }

    .scroll-container:hover .scroll-wrapper {
        animation-play-state: paused; /* মাউস নিলে থেমে যাবে */
    }

    /* দুই পাশের আবছা ভাব (Gradient Overlay) */
    .fade-overlay {
        position: relative;
    }
    .fade-overlay::before, .fade-overlay::after {
        content: "";
        position: absolute;
        top: 0; bottom: 0;
        width: 150px;
        z-index: 10;
        pointer-events: none;
    }
    .fade-overlay::before {
        left: 0;
        background: linear-gradient(to right, rgb(248 250 252), transparent); /* bg-slate-50 এর সাথে মিল রাখা */
