<%- include('../user/partials/header') %>

<div class="flex flex-col md:flex-row min-h-screen bg-[#F8FAFC]">
    <%- include('./partials/sidebar') %>

    <main class="flex-1 p-4 md:p-10">
        
        <div class="max-w-4xl mx-auto mb-8 flex justify-between items-end">
            <div>
                <h1 class="text-2xl font-bold text-gray-900">Add New Story</h1>
                <p class="text-gray-500 text-sm">Fill in the details to publish a new blog post.</p>
            </div>
            <a href="/admin/blogs" class="text-sm font-semibold text-green-700 hover:underline">
                <i class="fa-solid fa-list mr-1"></i> All Posts
            </a>
        </div>

        <div class="max-w-4xl mx-auto bg-white rounded-2xl shadow-sm border border-gray-200">
            <form action="/admin/blog/create" method="POST" enctype="multipart/form-data" class="p-6 md:p-10 space-y-6">
                
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Blog Title</label>
                    <input type="text" name="title" required 
                        class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-green-500/20 focus:border-green-600 focus:outline-none transition-all text-gray-800"
                        placeholder="Enter a descriptive title...">
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Category</label>
                        <select name="category" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-green-500/20 focus:border-green-600 focus:outline-none bg-white cursor-pointer">
                            <option value="Agriculture">Agriculture</option>
                            <option value="Education">Education</option>
                            <option value="Community">Community</option>
                            <option value="Success Story">Success Story</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Featured Image</label>
                        <input type="file" name="featuredImage" required accept="image/*"
                            class="w-full text-sm text-gray-500 file:mr-4 file:py-2.5 file:px-4 file:rounded-xl file:border-0 file:text-sm file:font-semibold file:bg-green-50 file:text-green-700 hover:file:bg-green-100 cursor-pointer border border-gray-300 rounded-xl py-1 px-2">
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Short Summary</label>
                    <textarea name="excerpt" rows="2" required
                        class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-green-500/20 focus:border-green-600 focus:outline-none transition-all"
                        placeholder="A brief introduction of the story..."></textarea>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Main Content</label>
                    <div class="rounded-xl overflow-hidden border border-gray-300">
                        <textarea id="editor" name="content"></textarea>
                    </div>
                </div>

                <div class="flex items-center gap-4 pt-4">
                    <button type="submit" name="status" value="published"
                        class="bg-green-700 text-white px-8 py-3 rounded-xl font-bold hover:bg-green-800 transition-all shadow-md">
                        Publish Post
                    </button>
                    <button type="submit" name="status" value="draft"
                        class="bg-gray-100 text-gray-600 px-8 py-3 rounded-xl font-bold hover:bg-gray-200 transition-all">
                        Save as Draft
                    </button>
                    <button type="reset" class="ml-auto text-sm font-medium text-gray-400 hover:text-red-500">
                        Discard
                    </button>
                </div>
            </form>
        </div>

                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10 mt-10">
            
            <% blogs.forEach(function(project){ %>
            <article class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition duration-300 group">
                <div class="relative overflow-hidden">
                    <img src="<%= project.featuredImage %>" alt="Blog Image" class="w-full h-56 object-cover group-hover:scale-110 transition duration-500">
                    <span class="absolute top-4 left-4 bg-orange-500 text-white text-xs font-bold px-3 py-1 rounded-full uppercase">Success Story</span>
                </div>
                <div class="p-6">
                    <div class="flex items-center gap-3 text-sm text-gray-500 mb-3">
                        <span><i class="fa-regular fa-calendar mr-1"></i> April 10, 2026</span>
                        <span><i class="fa-regular fa-clock mr-1"></i> 5 min read</span>
                    </div>
                    <h3 class="text-xl font-bold text-gray-900 mb-3 group-hover:text-green-700 transition">
                         <%= project.projectTitle %>
                    </h3>
                    <p class="text-gray-600 text-sm leading-relaxed mb-5 line-clamp-3">
                       <%= project.description %>
                    </p>
                    <a href="/stories/<%= project._id %>" class="text-green-600 font-bold text-sm flex items-center gap-2 hover:gap-3 transition-all">
                        READ MORE <i class="fa-solid fa-arrow-right"></i>
                    </a>

                    <a href="/stories/edit/<%= project._id %>" class="text-green-600 font-bold text-sm flex items-center gap-2 hover:gap-3 transition-all">
                        Edit <i class="fa-solid fa-arrow-right"></i>
                    </a>

                    <a href="/stories/delete/<%= project._id %>" class="text-red-500 font-bold text-sm flex items-center gap-2 hover:gap-3 transition-all">
                        Delete <i class="fa-solid fa-trash"></i>
                    </a>
                </div>
            </article>


            <% }) %>
        </div>
    </main>
</div>



<script src="https://cdn.ckeditor.com/ckeditor5/40.0.0/classic/ckeditor.js"></script>
<script>
    ClassicEditor.create(document.querySelector('#editor'), {
        toolbar: ['heading', '|', 'bold', 'italic', 'link', 'bulletedList', 'numberedList', 'blockQuote', 'undo', 'redo']
    }).catch(error => { console.error(error); });
</script>

<style>
    /* CKEditor সিম্পল লুক */
    .ck-editor__editable { min-height: 300px !important; border: none !important; }
    .ck.ck-editor__main>.ck-editor__editable:not(.ck-focused) { border: none !important; }
    .ck.ck-toolbar { border: none !important; border-bottom: 1px solid #E2E8F0 !important; background: #F8FAFC !important; }
</style>

<style>
    /* CKEditor Content Reset for Tailwind */
    .ck-content {
        font-family: 'Inter', sans-serif; /* বা আপনার পছন্দের ফন্ট */
        line-height: 1.6;
    }

    /* Bold & Italic Fix */
    .ck-content strong, .ck-content b {
        font-weight: bold !important;
    }
    .ck-content i, .ck-content em {
        font-style: italic !important;
    }

    /* Lists Fix (সবচেয়ে গুরুত্বপূর্ণ) */
    .ck-content ul {
        list-style-type: disc !important;
        margin-left: 1.5rem !important;
        padding-left: 1rem !important;
    }
    .ck-content ol {
        list-style-type: decimal !important;
        margin-left: 1.5rem !important;
        padding-left: 1rem !important;
    }
    .ck-content li {
        display: list-item !important;
    }

    /* Blockquote Fix */
    .ck-content blockquote {
        border-left: 4px solid #15803d !important; /* Green border */
        background: #f0fdf4 !important;
        padding: 10px 20px !important;
        font-style: italic !important;
        margin: 1rem 0 !important;
    }

    /* Header Styles inside Editor */
    .ck-content h2 { font-size: 1.5rem; font-weight: bold; margin-top: 1rem; }
    .ck-content h3 { font-size: 1.25rem; font-weight: bold; margin-top: 0.8rem; }

    /* CKEditor Custom UI Layout */
    .ck-editor__editable { min-height: 350px !important; border: none !important; padding: 20px !important; }
    .ck.ck-editor__main>.ck-editor__editable:not(.ck-focused) { border: none !important; }
    .ck.ck-toolbar { border: none !important; border-bottom: 1px solid #f1f5f9 !important; background: #f8fafc !important; }
</style>

<%- include('../user/partials/footer') %>