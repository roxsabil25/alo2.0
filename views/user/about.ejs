  <!-- ================= HISTORY (Image right) ================= -->
  <section class="max-w-6xl mx-auto py-16 px-6">
    <h2 class="text-3xl font-bold text-center mb-10">Brief History of Our Development Journey</h2>
    <div class="grid md:grid-cols-2 gap-10 items-center">
      <p class="text-gray-600 leading-relaxed">ALO is a grassroots, rights-based development organization working at the frontline of poverty reduction, climate resilience, and indigenous rights in northwest Bangladesh.</p>
      <div class="bg-gray-300 h-64 rounded-lg overflow-hidden">
        <img class="w-full h-full object-cover" src="/WhatsApp Image 2026-03-03 at 12.10.36 AM.jpeg" alt="History">
      </div>
    </div>
  </section>

  <!-- ================= HISTORY (Image left) ================= -->
  <section class="bg-emerald-50">
    <div class="max-w-6xl mx-auto py-10 px-6">
      <h2 class="text-3xl font-bold text-center mb-10"></h2>
      <div class="grid md:grid-cols-2 gap-10 items-center">
        <div class="bg-gray-300 h-64 rounded-lg overflow-hidden order-2 md:order-1">
          <img class="w-full h-full object-cover" src="/IMG_2461.JPG.jpeg" alt="History">
        </div>
        <p class="text-gray-600 leading-relaxed order-1 md:order-2">Founded in response to the devastating 1995 floods, ALO has evolved over nearly three decades into a trusted community-rooted NGO promoting sustainable livelihoods, food security, social justice, gender equality, and peacebuilding.</p>
      </div>
    </div>
  </section>

  <!-- ================= VISION & MISSION ================= -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-2 gap-12">
      <div class="bg-white p-8 rounded-2xl shadow-lg border-l-4 border-green-600">
        <h2 class="text-3xl font-bold mb-4 text-green-900">Vision</h2>
        <p class="text-gray-600 leading-relaxed">A peaceful, just, and inclusive society where all individuals live free from discrimination and poverty, enjoying equal rights, justice, and opportunities.</p>
      </div>
      <div class="bg-white p-8 rounded-2xl shadow-lg border-l-4 border-orange-500">
        <h2 class="text-3xl font-bold mb-4 text-orange-600">Mission</h2>
        <p class="text-gray-600 leading-relaxed">To empower marginalized and indigenous communities through rights-based and climate-resilient development, ensuring sustainable livelihoods, gender equality, and social harmony.</p>
      </div>
    </div>
  </section>

  <!-- ================= STRATEGIC FOCUS ================= -->
  <section class="py-16 bg-emerald-900 text-white">
    <div class="max-w-6xl mx-auto px-6">
