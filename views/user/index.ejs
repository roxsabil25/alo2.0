
<%- include('partials/header') %>

<!-- ================= HERO ================= -->
<section class="relative w-full overflow-hidden bg-black flex flex-col items-end justify-start h-[50vh] md:min-h-[60vh] pt-10 md:pt-20 pr-6 md:pr-16">

  <div class="absolute inset-0 z-0">
    <div class="w-full h-full bg-[url('/heroBg.jpeg')] bg-cover bg-[center_top_20%] sm:bg-center md:bg-fixed"></div>
    <div class="absolute inset-0 bg-black/70 md:bg-black/40 backdrop-blur-[1px]"></div>
  </div>

  <div class="relative z-10 w-full max-w-4xl text-white text-center flex flex-col items-end animate-in fade-in slide-in-from-top-5 duration-700">
    
    <div class="hidden md:block mb-4 bg-green-950/60 px-4 py-1.5 rounded-full border border-green-700/50 backdrop-blur-sm inline-block">
      <p class="  text-[10px] md:text-sm font-semibold text-green-300 uppercase tracking-widest">
        ALO — Creating Change Since 1996
      </p>
    </div>

    <h1 class="text-3xl sm:text-5xl md:text-6xl font-extrabold mb-6 leading-[1.1] tracking-tight">
      Together <span class="text-orange-400">We Can</span> Build <br class="hidden md:block"> a Just & Equal Society
    </h1>

    <div class="flex flex-col sm:flex-row gap-4 items-end justify-end w-full sm:w-auto">
      <a href="#" class="group inline-flex items-center justify-center gap-3 bg-white px-7 py-3.5 rounded-full text-center w-full sm:w-auto font-bold text-green-900 hover:bg-green-100 transition-all shadow-lg active:scale-95 text-sm md:text-base">
        Explore Our Projects
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 md:h-5 md:w-5 text-green-700 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
      </a>
      <a href="#" class="inline-block bg-orange-500 px-7 py-3.5 rounded-full text-center w-full sm:w-auto font-bold text-white hover:bg-orange-600 transition-all border-b-4 border-orange-700 shadow-lg active:scale-95 text-sm md:text-base">
        Donate Now
      </a>
    </div>
    
  </div>

</section>

<!-- ================= ABOUT ================= -->
<section class="py-10">
<div class="max-w-7xl mx-auto px-4 grid md:grid-cols-2 gap-10 items-center">

<div>
<h2 class="text-3xl font-bold text-green-800 mb-4">About ALO</h2>
<p class="text-gray-600 mb-4">
ALO- Assistance for Landless Organization is a Non-Profit dedicated to empowering the Landless and disadvantaged communities in Bangladesh.The initiative formally began on March 20, 1996, when a group of young, committed activists held a general meeting and resolved to establish an organization dedicated to ensuring equal rights for all and fostering long-term development...
</p>

<a href="/about" class="text-green-700 font-semibold">
Read More →
</a>
</div>

<img src="/IMG_2747.JPG.jpeg"
class="rounded-xl shadow-lg w-full h-64 object-cover">

</div>
</section>


<%- include('partials/focusAreas') %>


