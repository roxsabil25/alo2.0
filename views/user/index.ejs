<!-- ================= ONGOING PROJECTS ================= -->
<section class="py-16 bg-gray-100">

<div class="max-w-7xl mx-auto px-4">

  <!-- Section Title -->
  <div class="text-center mb-12">
    <h2 class="text-3xl font-bold text-green-800">
      Ongoing Projects
    </h2>
    <p class="text-gray-600 mt-2">
      Our current initiatives creating real impact in communities
    </p>
  </div>

  <!-- Project Cards -->
  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">

    <!-- Project 1 -->
<% projects.forEach(function(project){ %>

<div class="bg-white rounded-xl shadow hover:shadow-xl transition overflow-hidden">
      
      <img src="/uploads/<%= project.coverimage %>"
           class="h-56 w-full object-cover">

      <div class="p-6">
        <h3 class="text-xl font-semibold mb-2">
          <%= project.projectTitle %>
        </h3>

        <p class="text-gray-600 mb-4">
          <%= project.description %>
        </p>

        <a href="/showprojects/<%= project._id %>"
           class="inline-block bg-orange-500 text-white px-5 py-2 rounded hover:bg-orange-600">
           Learn More →
        </a>
      </div>
</div>

<% }) %>


    <!-- Project 2 -->
