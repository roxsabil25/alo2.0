<%- include('../user/partials/header') %>

<%- include('./partials/sidebar') %>

  <!-- Main Content -->
  <div class="flex-1 ml-64">
    <!-- Top Nav -->
    <header class="bg-white shadow px-6 py-4 flex justify-between items-center">
      <h2 class="text-xl font-semibold text-gray-800">Welcome, Admin</h2>
      <div>
        <button class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700">Profile</button>
      </div>
    </header>

    <!-- Content Area -->
    <main class="p-6">
      <!-- Cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-6">
        <div class="bg-white p-6 rounded shadow">
          <h3 class="text-lg font-semibold text-gray-700">Users</h3>
          <p class="text-2xl font-bold mt-2">1,234</p>
        </div>
        <div class="bg-white p-6 rounded shadow">
          <h3 class="text-lg font-semibold text-gray-700">Sales</h3>
          <p class="text-2xl font-bold mt-2">$12,345</p>
        </div>
        <div class="bg-white p-6 rounded shadow">
          <h3 class="text-lg font-semibold text-gray-700">Visitors</h3>
          <p class="text-2xl font-bold mt-2">23,456</p>
        </div>
      </div>

      <!-- Table -->
      <div class="bg-white p-6 rounded shadow">
        <h3 class="text-lg font-semibold text-gray-700 mb-4">Recent Users</h3>
        <table class="min-w-full border">
          <thead>
            <tr class="bg-gray-100">
              <th class="text-left py-2 px-4 border-b">Name</th>
              <th class="text-left py-2 px-4 border-b">Email</th>
              <th class="text-left py-2 px-4 border-b">Role</th>
              <th class="text-left py-2 px-4 border-b">Status</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="py-2 px-4 border-b">John Doe</td>
              <td class="py-2 px-4 border-b">john@example.com</td>
              <td class="py-2 px-4 border-b">Admin</td>
              <td class="py-2 px-4 border-b"><span class="text-green-600">Active</span></td>
            </tr>
            <tr>
              <td class="py-2 px-4 border-b">Jane Smith</td>
              <td class="py-2 px-4 border-b">jane@example.com</td>
              <td class="py-2 px-4 border-b">User</td>
              <td class="py-2 px-4 border-b"><span class="text-red-600">Inactive</span></td>
            </tr>
            <tr>
              <td class="py-2 px-4 border-b">Alex Brown</td>
              <td class="py-2 px-4 border-b">alex@example.com</td>
              <td class="py-2 px-4 border-b">User</td>
              <td class="py-2 px-4 border-b"><span class="text-green-600">Active</span></td>
            </tr>
          </tbody>
        </table>
      </div>
    </main>
  </div>

</body>
</html>