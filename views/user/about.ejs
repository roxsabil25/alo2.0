            <i class="fa-solid fa-child-reaching text-2xl"></i>
          </div>
          <h3 class="text-xl font-bold mb-3">Child Protection</h3>
          <p class="text-gray-600 text-sm">Committed to safeguarding children's rights and well-being through comprehensive protection protocols.</p>
        </div>
      </div>
    </div>
  </section>

