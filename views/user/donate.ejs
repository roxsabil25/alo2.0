                </div>

                <form class="space-y-6">
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        
                        <div class="relative group">
                            <label class="block text-sm font-semibold text-gray-700 mb-2 transition-colors group-focus-within:text-green-700">
                                <i class="fas fa-landmark mr-1"></i> Bank Name
                            </label>
                            <div class="flex items-center">
                                <input type="text" id="bankname" value="Uttara Bank PLC" disabled 
                                    class="w-full bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-green-500 focus:border-green-500 block p-3 pr-12 outline-none">
                                <button type="button" onclick="copyToClipboard('bankname')" 
                                    class="absolute right-2 p-2 bg-blue-600 hover:bg-blue-700 text-white rounded-md transition-all active:scale-90 copy-btn">
                                    <i class="fas fa-copy"></i>
                                </button>
                            </div>
                        </div>

                        <div class="relative group">
                            <label class="block text-sm font-semibold text-gray-700 mb-2 transition-colors group-focus-within:text-green-700">
                                <i class="fas fa-credit-card mr-1"></i> Account Number
                            </label>
                            <div class="flex items-center">
                                <input type="text" id="accountnumber" value="377214100041168" disabled 
                                    class="w-full bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-green-500 focus:border-green-500 block p-3 pr-12 outline-none font-mono font-bold tracking-wider">
                                <button type="button" onclick="copyToClipboard('accountnumber')" 
                                    class="absolute right-2 p-2 bg-blue-600 hover:bg-blue-700 text-white rounded-md transition-all active:scale-90 copy-btn">
                                    <i class="fas fa-copy"></i>
                                </button>
                            </div>
                        </div>

                    </div>

                    <div class="relative group">
                        <label class="block text-sm font-semibold text-gray-700 mb-2 transition-colors group-focus-within:text-green-700">
                            <i class="fas fa-user mr-1"></i> Account Name
                        </label>
                        <div class="flex items-center">
                            <input type="text" id="accountname" value="ALO-Assistance for Landless Organization" disabled 
                                class="w-full bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-green-500 focus:border-green-500 block p-3 pr-12 outline-none">
                            <button type="button" onclick="copyToClipboard('accountname')" 
                                class="absolute right-2 p-2 bg-blue-600 hover:bg-blue-700 text-white rounded-md transition-all active:scale-90 copy-btn">
                                <i class="fas fa-copy"></i>
                            </button>
                        </div>
                    </div>

                    <div class="relative group">
                        <label class="block text-sm font-semibold text-gray-700 mb-2 transition-colors group-focus-within:text-green-700">
                            <i class="fas fa-map-marker-alt mr-1"></i> Branch Address
                        </label>
                        <div class="flex items-center">
                            <input type="text" id="branchaddress" value="MofizUddin Market, Main Road, Naogaon-6500" disabled 
                                class="w-full bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-green-500 focus:border-green-500 block p-3 pr-12 outline-none">
                            <button type="button" onclick="copyToClipboard('branchaddress')" 
                                class="absolute right-2 p-2 bg-blue-600 hover:bg-blue-700 text-white rounded-md transition-all active:scale-90 copy-btn">
                                <i class="fas fa-copy"></i>
                            </button>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="relative group">
                            <label class="block text-sm font-semibold text-gray-700 mb-2 uppercase tracking-wide italic text-[10px]">Mnemonic</label>
                            <div class="flex items-center">
                                <input type="text" id="mnemonic" value="NAOG" disabled 
                                    class="w-full bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg p-3 pr-12 outline-none">
                                <button type="button" onclick="copyToClipboard('mnemonic')" 
                                    class="absolute right-2 p-2 bg-blue-600 hover:bg-blue-700 text-white rounded-md transition-all active:scale-90 copy-btn">
                                    <i class="fas fa-copy"></i>
                                </button>
                            </div>
                        </div>

                        <div class="relative group">
                            <label class="block text-sm font-semibold text-gray-700 mb-2 transition-colors group-focus-within:text-green-700">
                                <i class="fas fa-globe mr-1"></i> SWIFT Code
                            </label>
                            <div class="flex items-center">
                                <input type="text" id="swiftcode" value="UTBLBDDH469" disabled 
                                    class="w-full bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg p-3 pr-12 outline-none">
                                <button type="button" onclick="copyToClipboard('swiftcode')" 
                                    class="absolute right-2 p-2 bg-blue-600 hover:bg-blue-700 text-white rounded-md transition-all active:scale-90 copy-btn">
                                    <i class="fas fa-copy"></i>
                                </button>
                            </div>
                        </div>
                    </div>

                    <hr class="border-gray-200">

                    <div class="bg-blue-50 p-5 rounded-xl border border-blue-100">
                        <h3 class="text-blue-800 font-bold mb-3 flex items-center">
                            <i class="fas fa-info-circle mr-2"></i> Payment Instructions
                        </h3>
                        <ol class="list-decimal list-inside text-sm text-blue-700 space-y-2 ml-1">
                            <li>Use the account details above for bank transfers</li>
                            <li>Include your full name as reference when making payment</li>
                            <li>Allow 24-48 hours for payment processing</li>
                            <li>Keep your transaction receipt for reference</li>
                        </ol>
                    </div>

                    <div class="bg-amber-50 p-5 rounded-xl border border-amber-100 italic">
                        <h3 class="text-amber-800 font-bold mb-2 flex items-center">
                            <i class="fas fa-exclamation-circle mr-2"></i> Important Note
                        </h3>
                        <p class="text-sm text-amber-700">For international transfers, please use the SWIFT code provided. Contact support if you need assistance with your transaction.</p>
                    </div>

                </form>
            </div>
            
            <div class="bg-gray-50 p-4 text-center border-t border-gray-200">
                <p class="text-xs text-gray-500">&copy; 2026 ALO Organization. All rights reserved.</p>
            </div>
        </div>
    </div>

    <script>
        function copyToClipboard(inputId) {
            const input = document.getElementById(inputId);
            // আমরা সরাসরি ভ্যালু কপি করব কারণ input টা disabled
            const textToCopy = input.value;
            
            navigator.clipboard.writeText(textToCopy).then(() => {
                // Show confirmation on the button
                const button = event.currentTarget;
                const originalHtml = button.innerHTML;
                
                button.innerHTML = '<i class="fas fa-check"></i>';
                button.classList.replace('bg-blue-600', 'bg-green-700');
                
                setTimeout(() => {
                    button.innerHTML = originalHtml;
                    button.classList.replace('bg-green-700', 'bg-blue-600');
                }, 2000);
            });
        }
    </script>
<%- include('partials/footer') %>