<%- include('partials/header') %>

    <div class="min-h-screen flex items-center justify-center p-6">
        <div class="bg-white w-full max-w-2xl rounded-2xl shadow-2xl overflow-hidden border border-gray-200">
            
            <div class="bg-green-800 p-6 text-white relative">
                <a class="absolute left-6 top-6 text-green-200 hover:text-white transition-colors text-sm font-medium" href="/">
